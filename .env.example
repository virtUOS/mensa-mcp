# .env.example

# --- Server ---
MENSA_HOST=127.0.0.1
MENSA_PORT=8080
MENSA_LOG_LEVEL=info
MENSA_ALLOWED_HOSTS='["localhost"]'

# --- Scraper ---
MENSA_API_URL=https://sw-osnabrueck.maxmanager.xyz/inc/ajax-php_konnektor.inc.php
MENSA_API_TIMEOUT=10.0
MENSA_PDF_BASE_URL=https://www.maxmanager.de/daten-extern/os-neu/pdf/wochenplaene

# --- Cache ---
MENSA_CACHE_TTL=86400

# --- Data Overrides ---
# Path to JSON file for overriding restaurants, allergens, etc.
# Leave empty to use built-in defaults.
MENSA_CONFIG_FILE=
